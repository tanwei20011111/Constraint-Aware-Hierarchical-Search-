# OpenAI-compatible API settings
# Chat model endpoint
OPENAI_CHAT_BASE_URL=<your_chat_base_url>
OPENAI_CHAT_API_KEY=<your_chat_api_key>
OPENAI_MODEL=<your_model_name>

# Embedding model endpoint
OPENAI_EMBEDDING_BASE_URL=<your_embedding_base_url>
OPENAI_EMBEDDING_API_KEY=<your_embedding_api_key>
OPENAI_EMBEDDING_MODEL=<your_embedding_model>
# OPENAI_EMBEDDING_DIMENSIONS=1024


# Optional overrides
OPENAI_TEMPERATURE=0
OPENAI_MAX_TOKENS=30000
